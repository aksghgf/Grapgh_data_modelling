# Neo4j (used by scripts/ingest.py and backend)
NEO4J_URI=bolt://localhost:7687
# Use either NEO4J_USER or NEO4J_USERNAME (Aura often documents the latter).
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# Groq (backend QueryService — NL to Cypher)
GROQ_API_KEY=your-groq-api-key
# Default: llama-3.3-70b-versatile (see https://console.groq.com/docs/models)
GROQ_MODEL=llama-3.3-70b-versatile

# Backend HTTP
PORT=5000
# Comma-separated browser origins allowed to call the API (required for hosted frontend + Render API).
# Example: CORS_ORIGIN=http://localhost:5173,https://your-app.vercel.app
CORS_ORIGIN=http://localhost:5173
# Optional: set on Render if preflight fails for Vercel *preview* URLs (new URL per deploy).
# Prefer listing real origins in CORS_ORIGIN for production.
# CORS_ALLOW_ALL_ORIGINS=true

# Frontend dev: where Vite proxies /api (must match backend PORT)
# VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:5000

# Optional: SAP O2C data directory for ingest (default: backend/data/sap-o2c-data)
# SAP_O2C_DATA_DIR=backend/data/sap-o2c-data
